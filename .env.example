# Environment variables for NobleLogic Trading System
# Security Configuration
ENCRYPTION_KEY=${ENCRYPTION_KEY}  # Will be auto-generated on first run

# Binance.US API Configuration
BINANCE_US_API_KEY=${BINANCE_US_API_KEY}
BINANCE_US_SECRET_KEY=${BINANCE_US_SECRET_KEY}
BINANCE_US_IP_WHITELIST=${YOUR_IP_ADDRESS}

# Trading Parameters
INITIAL_CAPITAL=100
TARGET_DAILY_PROFIT=500
MAX_DAILY_LOSS=25
RISK_PER_TRADE=0.02  # 2% max risk per trade

# System Security
API_RATE_LIMIT=10
MAX_REQUEST_PER_MINUTE=30
SECURITY_LEVEL=high

# Database Configuration
DB_ENCRYPTION_ENABLED=true
SECURE_LOG_LEVEL=info

# Monitoring Configuration
ALERT_EMAIL=${YOUR_EMAIL}
TELEGRAM_BOT_TOKEN=${YOUR_TELEGRAM_TOKEN}
TELEGRAM_CHAT_ID=${YOUR_CHAT_ID}